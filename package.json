{
  "name": "breef-cc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003 --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "RUN_DB_TESTS=true vitest run",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "inngest:dev": "npx inngest-cli@latest dev"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.15"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@sentry/cli",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@clerk/nextjs": "^7.4.2",
    "@clerk/ui": "^1.14.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.55.0",
    "ai": "^6.0.194",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^4.5.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "svix": "^1.95.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/components": "^1.0.12",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "react-email": "^6.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
